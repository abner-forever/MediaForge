WEIBO_COOKIE=
WEIBO_UID=
# own=只抓本人主页；celebrities=按 WEIBO_CELEBRITIES 聚合；mixed=明星+本人合并
WEIBO_FETCH_MODE=celebrities
# 逗号分隔；留空时请把 WEIBO_FETCH_MODE 改为 own（或仅用本人时间线推断）
WEIBO_CELEBRITIES=周也,张婧仪,鞠婧祎,赵丽颖,孔雪儿
# 会与明星名拼接为「张三 美图」「张三 美妆」等综合搜（类似你在美妆/日常流里找的）
WEIBO_SEARCH_TAGS=美图,日常,时装周,美妆,穿搭
# 每个关键词组合的搜页最多翻页数（与时间线分页 WEIBO_PAGES 分开，避免过多请求）
WEIBO_KEYWORD_PAGES=1
# 时间线发帖「猜场景」时额外匹配的词（可与 WEIBO_SEARCH_TAGS 并列）
WEIBO_SCENE_EXTRA_TAGS=红毯,GQ,杀青,私服,街拍,路透

# 下载后水印启发式筛查（调高阈值会减少误删；调低则更严格）
WATERMARK_FILTER=true
WATERMARK_CORNER_RATIO=1.38
WATERMARK_BOTTOM_RATIO=1.48
# true: 无干净图/低于阈值就跳过帖子；false: 只做过滤不过门槛
WATERMARK_STRICT_MODE=true
# 每条帖子至少保留多少张“非疑似水印”图才允许继续
MIN_CLEAN_IMAGES=3
# 严格模式下若仍不足，是否允许降级继续（true=继续，false=跳过）
ALLOW_WATERMARK_FALLBACK=false

AI_API_KEY=
MIMO_API_KEY=
GLM_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
AI_PROVIDER=mimo
AI_MODEL=mimo-chat
# 必填：填写你的小米 Mimo OpenAI 兼容地址（示例：https://xxx/chat/completions 或 https://xxx/v1）
AI_BASE_URL=
POST_LIMIT=3
WEIBO_PAGES=2
REQUEST_TIMEOUT=20
RETRY_TIMES=3
PUBLISH_INTERVAL_SECONDS=10
REQUIRE_CONFIRM=true

# CLI：若仍只见 data/images/*.jpg，多半是旧缓存。新结构为 images/<艺人>/<选题>/<帖子>/
# 重新下载：python main.py --dry-run --ignore-post-cache
